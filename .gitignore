target/
**/*.rs.bk
Cargo.lock.bak

# Local editor files
.vscode/
.idea/

# Test suite caches (fetched by `cargo xtask fetch-testsuites`).
# Each suite dir is ignored except its xfail.toml and README.md (checked in).
third_party/testsuites/c-testsuite/*
!third_party/testsuites/c-testsuite/xfail.toml
!third_party/testsuites/c-testsuite/README.md
third_party/testsuites/chibicc/*
!third_party/testsuites/chibicc/xfail.toml
!third_party/testsuites/chibicc/README.md
third_party/testsuites/gcc-torture/*
!third_party/testsuites/gcc-torture/xfail.toml
!third_party/testsuites/gcc-torture/README.md
!third_party/testsuites/gcc-torture/smoke-subset.txt
third_party/testsuites/tcc-tests2/*
!third_party/testsuites/tcc-tests2/xfail.toml
!third_party/testsuites/tcc-tests2/README.md
third_party/testsuites/llvm-test-suite/*
!third_party/testsuites/llvm-test-suite/xfail.toml
!third_party/testsuites/llvm-test-suite/README.md
third_party/testsuites/csmith/*
!third_party/testsuites/csmith/xfail.toml
!third_party/testsuites/csmith/README.md
third_party/.cache/

# Fuzz corpora: generated inputs are ignored, but the curated seed
# corpora checked in under fuzz/corpus/<target>/ are not (see
# scripts/fuzz/seed-*.{sh,ps1} and tasks 03-lex/12-fuzz-target,
# 04-preprocess/19-fuzz-target).
fuzz/corpus/*
!fuzz/corpus/lex/
fuzz/corpus/lex/*
!fuzz/corpus/lex/*.c
!fuzz/corpus/preprocess/
fuzz/corpus/preprocess/*
!fuzz/corpus/preprocess/*.c
!fuzz/corpus/preprocess/*.h
!fuzz/corpus/preprocess/*.rccfuzz
fuzz/artifacts/

# Conformance reports
docs/conformance.json
